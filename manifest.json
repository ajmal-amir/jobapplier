{
  "manifest_version": 3,
  "name": "AI Job Applicant Assistant",
  "version": "1.0.0",
  "description": "Automates job searching and applying on LinkedIn & Indeed using your resume and OpenAI. Sends email logs of all applications.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "notifications",
    "alarms"
  ],

  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://api.openai.com/*",
    "https://api.emailjs.com/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": [
        "utils/storage.js",
        "utils/openai.js",
        "content/form-filler.js",
        "content/linkedin.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.indeed.com/*"],
      "js": [
        "utils/storage.js",
        "utils/openai.js",
        "content/form-filler.js",
        "content/indeed.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/storage.js",
        "utils/openai.js",
        "content/form-filler.js"
      ],
      "run_at": "document_idle",
      "exclude_matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*"
      ]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Job Applicant",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options/options.html",

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
